<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <!-- Assembly Information -->
    <PropertyGroup>
        <Version>0.6.0</Version>
        <FileVersion>0.6.0.0</FileVersion>
        <AssemblyVersion>0.6.0.0</AssemblyVersion>
        <Authors>Nandor Toth</Authors>
        <Company>Nandor Toth</Company>
        <Product>RTL-SDR Manager Library for .NET</Product>
    </PropertyGroup>

    <!-- NuGet Package Metadata -->
    <PropertyGroup>
        <PackageId>RtlSdrManager</PackageId>
        <Title>RTL-SDR Manager for .NET</Title>
        <Description>A modern .NET library for managing RTL-SDR devices with support for async operations, multiple tuner types, and advanced features.</Description>
        <PackageTags>rtl-sdr;sdr;radio;rtl2832;software-defined-radio;rf;tuner</PackageTags>
        <PackageProjectUrl>https://github.com/nandortoth/rtlsdr-manager</PackageProjectUrl>
        <RepositoryUrl>https://github.com/nandortoth/rtlsdr-manager</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>GPL-3.0-or-later</PackageLicenseExpression>
        <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <Copyright>Copyright (c) 2018-2025 Nandor Toth</Copyright>
    </PropertyGroup>

    <!-- NuGet Package Build Settings -->
    <PropertyGroup>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    </PropertyGroup>

    <!-- Release Notes -->
    <PropertyGroup>
        <PackageReleaseNotes>
            v0.6.0 (2026-03-14):

            ADDED:
            - Raw buffer mode for zero-copy sample delivery via Channel&lt;RawSampleBuffer&gt;
            - RawSampleBuffer type wrapping pooled byte[] buffers from ArrayPool&lt;byte&gt;
            - UseRawBufferMode property to opt-in to raw buffer mode (default: false)
            - GetRawSamplesFromAsyncBuffer() method returning RawSampleBuffer?
            - Demo5: Raw buffer mode sample application

            PERFORMANCE:
            - Raw buffer mode eliminates per-sample IQData object allocation in async callback
            - Single memcpy per callback replaces per-sample struct construction and queue operations
            - ArrayPool&lt;byte&gt; reuse eliminates steady-state heap allocation in native callback path
            - Channel&lt;RawSampleBuffer&gt; with SingleWriter/SingleReader for lock-free buffer handoff

            See CHANGELOG.md for complete details.
        </PackageReleaseNotes>
    </PropertyGroup>

    <!-- Package Icon -->
    <PropertyGroup>
        <PackageIcon>RtlSdrManager.Icon.128.png</PackageIcon>
    </PropertyGroup>

    <ItemGroup>
        <None Include="../../design/icon/RtlSdrManager.Icon.128.png" Pack="true" PackagePath="/" />
    </ItemGroup>

    <!-- Include README in package -->
    <ItemGroup>
        <None Include="../../README.md" Pack="true" PackagePath="/" />
    </ItemGroup>

    <!-- Source Link Support (for debugging) -->
    <ItemGroup>
        <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
    </ItemGroup>
</Project>
