<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <!-- Assembly Information -->
    <PropertyGroup>
        <Version>0.5.3</Version>
        <FileVersion>0.5.3.0</FileVersion>
        <AssemblyVersion>0.5.3.0</AssemblyVersion>
        <Authors>Nandor Toth</Authors>
        <Company>Nandor Toth</Company>
        <Product>RTL-SDR Manager Library for .NET</Product>
    </PropertyGroup>

    <!-- NuGet Package Metadata -->
    <PropertyGroup>
        <PackageId>RtlSdrManager</PackageId>
        <Title>RTL-SDR Manager for .NET</Title>
        <Description>A modern .NET library for managing RTL-SDR devices with support for async operations, multiple tuner types, and advanced features.</Description>
        <PackageTags>rtl-sdr;sdr;radio;rtl2832;software-defined-radio;rf;tuner</PackageTags>
        <PackageProjectUrl>https://github.com/nandortoth/rtlsdr-manager</PackageProjectUrl>
        <RepositoryUrl>https://github.com/nandortoth/rtlsdr-manager</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>GPL-3.0-or-later</PackageLicenseExpression>
        <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <Copyright>Copyright (c) 2018-2025 Nandor Toth</Copyright>
    </PropertyGroup>

    <!-- NuGet Package Build Settings -->
    <PropertyGroup>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    </PropertyGroup>

    <!-- Release Notes -->
    <PropertyGroup>
        <PackageReleaseNotes>
            v0.5.3 (2026-03-07):

            PERFORMANCE:
            - Pre-allocated List capacity in synchronous ReadSamples to eliminate dynamic resizing
            - Batched IQ sample construction in async callback to improve cache locality
            - Replaced busy-wait spin loop in GetSamplesFromAsyncBuffer with single TryDequeue
            - Pre-allocated List capacity in GetSamplesFromAsyncBuffer
            - Cached supported tuner gains from librtlsdr to avoid repeated P/Invoke calls

            FIXES:
            - Demo4 now opens all available devices instead of only the first one

            See CHANGELOG.md for complete details.
        </PackageReleaseNotes>
    </PropertyGroup>

    <!-- Package Icon -->
    <PropertyGroup>
        <PackageIcon>RtlSdrManager.Icon.128.png</PackageIcon>
    </PropertyGroup>

    <ItemGroup>
        <None Include="../../design/icon/RtlSdrManager.Icon.128.png" Pack="true" PackagePath="/" />
    </ItemGroup>

    <!-- Include README in package -->
    <ItemGroup>
        <None Include="../../README.md" Pack="true" PackagePath="/" />
    </ItemGroup>

    <!-- Source Link Support (for debugging) -->
    <ItemGroup>
        <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
    </ItemGroup>
</Project>
